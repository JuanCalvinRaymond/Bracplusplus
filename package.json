{
	"name": "bracplusplus",
	"displayName": "BracPlusPlus",
	"description": "Ultimate bracket manipulation plugins. Mainly for C++",
	"version": "1.0.0",
	"publisher": "juan-raymond",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.111.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/JuanCalvinRaymond/Bracplusplus.git"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
	],
	"main": "./out/src/bracketSelectMain",
	"contributes": {
		"commands": [
			{
				"command": "bracket-plus-plus.select",
				"title": "BracPlusPlus: Select Inside Bracket"
			},
			{
				"command": "bracket-plus-plus.undo-select",
				"title": "BracPlusPlus: UndoSelect"
			},
			{
				"command": "bracket-plus-plus.deleteContent",
				"title": "BracPlusPlus: Delete Inside Bracket"
			}
		],
		"keybindings": [
			{
				"command": "bracket-plus-plus.undo-select",
				"key": "alt+z",
				"mac": "alt+z",
				"when": "editorTextFocus"
			},
			{
				"command": "bracket-plus-plus.select",
				"key": "alt+a",
				"mac": "alt+a",
				"when": "editorTextFocus",
			},
			{
				"command": "bracket-plus-plus.deleteContent",
				"key": "alt+d",
				"mac": "alt+d",
				"when": "editorTextFocus",
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "tslint -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^25.0.1",
		"@types/vscode": "^1.105.0",
		"tslint": "^6.1.3",
		"typescript": "^5.3.0"
	},
	"dependencies": {},
